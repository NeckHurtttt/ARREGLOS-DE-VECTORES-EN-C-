#include <iostream>
#include <cmath>
using namespace std;
class Vector{
float v[100];
int n;
public:
void ingresar(){
cin>>n;
for(int i=0;i<n;i++)
cin>>v[i];
}
void diferencia(){
float d=0;
for(int i=0;i<n-1;i++)
if(abs(v[i+1]-v[i])>d)
d=abs(v[i+1]-v[i]);
cout<<d;
}
};
int main(){
Vector a;
a.ingresar();
a.diferencia();
}
